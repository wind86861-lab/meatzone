PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/vipstroy

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_SECRET

# Comma-separated list of allowed frontend origins (required in production)
# Add your domain here
ALLOWED_ORIGINS=https://vipstroy.uz,https://www.vipstroy.uz,http://localhost:5173

# =====================================================
# STAGE 1: REDIS CONFIGURATION
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =====================================================
# STAGE 1: TELEGRAM BOT CONFIGURATION
# =====================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ADMIN_GROUP=your_admin_group_chat_id
TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_OWNER_ID=123456789
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
SITE_URL=https://vipstroy.uz
ADMIN_PANEL_URL=https://vipstroy.uz

# =====================================================
# STAGE 4: PAYME INTEGRATION
# =====================================================
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_KEY=your_payme_secret_key

# =====================================================
# STAGE 4: CLICK INTEGRATION
# =====================================================
CLICK_SERVICE_ID=your_click_service_id
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SECRET_KEY=your_click_secret_key

# =====================================================
# PAYMENT WEBHOOK SECURITY (legacy)
# =====================================================
PAYMENT_WEBHOOK_SECRET=CHANGE_THIS_TO_STRONG_WEBHOOK_SECRET

# =====================================================
# STAGE 1: LOGGING
# =====================================================
LOG_LEVEL=info

# =====================================================
# STAGE 1: RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# =====================================================
# MONITORING
# =====================================================
# Sentry DSN (leave blank to disable)
SENTRY_DSN=

# =====================================================
# ADMIN PANEL
# =====================================================
# Full URL shown in Telegram admin group "Open in panel" button
# (already set above)
